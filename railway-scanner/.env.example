# ── Required ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Secret key used by Vercel frontend to call scanner API
SCANNER_API_KEY=your-random-scanner-api-key

# ── Blockchain RPCs ──────────────────────────────────
RPC_URL_SIDRA=https://node.sidrachain.com
RPC_URL_BSC=https://bsc-dataseed.binance.org

# ── Scanner settings ─────────────────────────────────
# Scan interval in milliseconds (default: 15000 = 15s)
SCAN_INTERVAL_MS=15000

# Max blocks to scan per cycle (default: 50)
MAX_BLOCKS_PER_SCAN=50

# Minimum confirmations before crediting deposit (default: 3)
MIN_CONFIRMATIONS=3

# ── Withdrawal processing (optional) ────────────────
# Set to false to disable withdrawal broadcasting
PROCESS_WITHDRAWALS=false

# Hot wallet private keys (only needed if PROCESS_WITHDRAWALS=true)
# HOT_WALLET_PRIVATE_KEY_SIDRA=0x...
# HOT_WALLET_PRIVATE_KEY_BSC=0x...

# ── Server ───────────────────────────────────────────
PORT=3001
